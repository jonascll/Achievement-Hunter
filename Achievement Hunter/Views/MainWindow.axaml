<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Achievement_Hunter.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:views="using:Achievement_Hunter.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Achievement_Hunter.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Achievement_Hunter">
    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:GameListViewModel}">
            <views:GameList></views:GameList>
        </DataTemplate>
    </Window.DataTemplates>
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ContentControl Content="{Binding CurrentPage}"/>
</Window>
