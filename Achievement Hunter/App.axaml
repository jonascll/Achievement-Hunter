             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Achievement_Hunter.App"
             xmlns:local="using:Achievement_Hunter"
             RequestedThemeVariant="Dark">
         

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
